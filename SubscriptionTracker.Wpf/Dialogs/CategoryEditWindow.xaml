<Window x:Class="SubscriptionTracker.Wpf.Dialogs.CategoryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="460"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <Border Background="{DynamicResource AppBackgroundBrush}" Padding="24">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel>
        <TextBlock FontSize="14"
                   Foreground="{DynamicResource AppMutedBrush}"
                   Text="{DynamicResource CategoryEditorName}" />
        <TextBox Margin="0,6,0,16"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock FontSize="14"
                   Foreground="{DynamicResource AppMutedBrush}"
                   Text="{DynamicResource CategoryEditorColor}" />
        <TextBox Margin="0,6,0,8"
                 MaxLength="7"
                 Text="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                   Text="{DynamicResource CategoryEditorColorHint}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="0,20,0,0"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Width="120"
                Click="SaveClick"
                Style="{StaticResource PrimaryButtonStyle}"
                Content="{DynamicResource CategorySave}" />
        <Button Width="120"
                IsCancel="True"
                Content="{DynamicResource SubscriptionEditorCancel}" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
