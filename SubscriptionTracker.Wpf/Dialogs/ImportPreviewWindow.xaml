<Window x:Class="SubscriptionTracker.Wpf.Dialogs.ImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="980"
        Height="720"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </Window.Resources>

  <Border Background="{DynamicResource AppBackgroundBrush}"
          BorderBrush="{DynamicResource AppBorderBrush}"
          BorderThickness="1"
          CornerRadius="24"
          Padding="22">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            MouseLeftButtonDown="HeaderMouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="44"
                Height="44"
                Background="{DynamicResource AppAccentBrush}"
                CornerRadius="22">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="20"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="i" />
        </Border>

        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
          <TextBlock FontSize="22"
                     FontWeight="SemiBold"
                     Text="{Binding WindowTitle}" />
          <TextBlock Margin="0,4,0,0"
                     Foreground="{DynamicResource AppMutedBrush}"
                     Text="{DynamicResource ImportPreviewSubtitle}" />
        </StackPanel>
      </Grid>

      <Border Grid.Row="1"
              Margin="0,18,0,0"
              Style="{StaticResource CardBorderStyle}">
        <TextBlock Text="{Binding SummaryText}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource AppForegroundBrush}" />
      </Border>

      <Border Grid.Row="2"
              Margin="0,14,0,0"
              Style="{StaticResource CardBorderStyle}"
              Visibility="{Binding HasWarnings, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
          <TextBlock FontWeight="SemiBold"
                     Text="{DynamicResource ImportPreviewWarningsTitle}" />
          <ItemsControl Margin="0,10,0,0"
                        ItemsSource="{Binding Warnings}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,0,0,6"
                           Foreground="{DynamicResource AppMutedBrush}"
                           Text="{Binding}"
                           TextWrapping="Wrap" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Grid.Row="3"
              Margin="0,14,0,0"
              Style="{StaticResource CardBorderStyle}">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{DynamicResource ImportPreviewRowsTitle}" />

            <TextBlock Grid.Column="1"
                       Margin="0,0,14,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource AppMutedBrush}"
                       Text="{Binding SelectedSummaryText}" />

            <CheckBox Grid.Column="2"
                      VerticalAlignment="Center"
                      IsChecked="{Binding SelectAllImportable}"
                      Content="{DynamicResource ImportPreviewSelectAll}" />
          </Grid>

          <ListBox ItemsSource="{Binding Items}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,10" />
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource AppCardBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="2.1*" />
                      <ColumnDefinition Width="1.1*" />
                      <ColumnDefinition Width="1*" />
                      <ColumnDefinition Width="1.1*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              Margin="0,2,14,0"
                              VerticalAlignment="Top"
                              IsChecked="{Binding IsSelected}"
                              IsEnabled="{Binding IsSelectable}" />

                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 Text="{Binding Name}" />
                      <TextBlock Margin="0,4,0,0"
                                 Foreground="{DynamicResource AppMutedBrush}"
                                 Text="{Binding CategoryName}" />
                      <TextBlock Margin="0,6,0,0"
                                 Foreground="{DynamicResource AppMutedBrush}"
                                 Visibility="{Binding HasNote, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Text="{Binding Note}"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                      <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                                 Text="{DynamicResource SubscriptionsAmount}" />
                      <TextBlock Margin="0,4,0,0"
                                 FontWeight="SemiBold"
                                 Text="{Binding AmountLabel}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                      <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                                 Text="{DynamicResource SubscriptionsCycle}" />
                      <TextBlock Margin="0,4,0,0"
                                 Text="{Binding CycleLabel}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                      <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                                 Text="{DynamicResource SubscriptionsNextCharge}" />
                      <TextBlock Margin="0,4,0,0"
                                 Text="{Binding NextPaymentLabel}" />
                    </StackPanel>

                    <StackPanel Grid.Column="5" HorizontalAlignment="Right">
                      <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                                 HorizontalAlignment="Right"
                                 Text="{DynamicResource ImportPreviewActionColumn}" />
                      <Border Margin="0,4,0,0"
                              Style="{StaticResource StatusBadgeBorderStyle}"
                              Background="{Binding ActionColorHex, Converter={StaticResource HexToBrushConverter}}">
                        <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                   Text="{Binding ActionLabel}" />
                      </Border>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <StackPanel Grid.Row="4"
                  Margin="0,20,0,0"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Width="120"
                Margin="0,0,10,0"
                IsCancel="True"
                Content="{DynamicResource SubscriptionEditorCancel}" />
        <Button Width="160"
                IsEnabled="{Binding CanImport}"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="ImportClick"
                Content="{DynamicResource ImportPreviewConfirm}" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
