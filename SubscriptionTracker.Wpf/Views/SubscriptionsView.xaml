<UserControl x:Class="SubscriptionTracker.Wpf.Views.SubscriptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <Style x:Key="SubscriptionListItemStyle" TargetType="ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Root"
                    Background="{DynamicResource AppCardBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentAltBrush}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppSecondaryCardBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <DockPanel>
    <Border DockPanel.Dock="Top" Style="{StaticResource CardBorderStyle}">
      <StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="180" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{DynamicResource SubscriptionsTitle}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource AppMutedBrush}"
                       Text="{DynamicResource SubscriptionsSubtitle}" />
          </StackPanel>

          <TextBox Grid.Column="1"
                   Margin="12,0,12,0"
                   VerticalContentAlignment="Center"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

          <ComboBox Grid.Column="2"
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding Filters}"
                    SelectedItem="{Binding SelectedFilter}" />
        </Grid>

        <UniformGrid Margin="0,16,0,0" Columns="3">
          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Padding="14">
            <StackPanel>
              <TextBlock Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsInList}" />
              <TextBlock Margin="0,6,0,0" FontSize="22" FontWeight="Bold" Text="{Binding VisibleCount}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Padding="14">
            <StackPanel>
              <TextBlock Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsActive}" />
              <TextBlock Margin="0,6,0,0" FontSize="22" FontWeight="Bold" Text="{Binding ActiveCount}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource CardBorderStyle}" Padding="14">
            <StackPanel>
              <TextBlock Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsMonthlyLoad}" />
              <TextBlock Margin="0,6,0,0" FontSize="22" FontWeight="Bold" Text="{Binding VisibleMonthlyTotalLabel}" />
            </StackPanel>
          </Border>
        </UniformGrid>

        <WrapPanel Margin="0,16,0,0">
          <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddCommand}" Content="{DynamicResource SubscriptionsAdd}" />
          <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditCommand}" Content="{DynamicResource SubscriptionsEdit}" />
          <Button Style="{StaticResource NeutralButtonStyle}" Command="{Binding MarkPaidCommand}" Content="{DynamicResource SubscriptionsMarkPaid}" />
          <Button Style="{StaticResource NeutralButtonStyle}" Command="{Binding SkipCommand}" Content="{DynamicResource SubscriptionsSkip}" />
          <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ToggleActiveCommand}" Content="{DynamicResource SubscriptionsToggle}" />
          <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ImportCommand}" Content="{DynamicResource SubscriptionsImport}" />
          <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UndoLastImportCommand}" Content="{DynamicResource SubscriptionsUndoLastImport}" />
          <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DownloadImportTemplateCommand}" Content="{DynamicResource SubscriptionsImportTemplate}" />
          <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportCommand}" Content="{DynamicResource SubscriptionsExport}" />
          <Button Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteCommand}" Content="{DynamicResource SubscriptionsDelete}" />
        </WrapPanel>

        <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}" Padding="16">
          <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource ImportHistoryTitle}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource AppMutedBrush}"
                       Text="{DynamicResource ImportHistorySubtitle}" />

            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding ImportSessions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,10"
                          Padding="12"
                          Background="{DynamicResource AppPanelBrush}"
                          BorderBrush="{DynamicResource AppBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="12">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="SemiBold" Text="{Binding SourceFileName}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource AppMutedBrush}"
                                   Text="{Binding CreatedAtLabel}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding RowsLabel}" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{DynamicResource AppMutedBrush}"
                                   Text="{Binding SummaryLabel}" />
                      </StackPanel>

                      <Border Grid.Column="1"
                              Margin="12,0,0,0"
                              VerticalAlignment="Top"
                              Style="{StaticResource StatusBadgeBorderStyle}"
                              Background="{DynamicResource AppAccentBrush}"
                              Visibility="{Binding IsLatest, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource StatusBadgeTextStyle}" Text="{DynamicResource ImportHistoryLatestBadge}" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,12,0,0"
                       Foreground="{DynamicResource AppMutedBrush}"
                       Text="{DynamicResource ImportHistoryEmpty}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasImportSessions}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Style="{StaticResource CardBorderStyle}">
      <ListBox ItemsSource="{Binding ItemsView}"
               SelectedItem="{Binding SelectedItem}"
               Background="Transparent"
               BorderThickness="0"
               ItemContainerStyle="{StaticResource SubscriptionListItemStyle}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.1*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0" Margin="0,0,18,0">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" />
                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{Binding Description}" />
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsCategory}" />
                <TextBlock Margin="0,4,0,0" FontWeight="SemiBold" Text="{Binding CategoryName}" />
                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsCycle}" />
                <TextBlock Margin="0,4,0,0" Text="{Binding CycleLabel}" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsAmount}" />
                <TextBlock Margin="0,4,0,0" FontWeight="SemiBold" Text="{Binding AmountLabel}" />
                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsMonthlyAmount}" />
                <TextBlock Margin="0,4,0,0" Text="{Binding MonthlyCostLabel}" />
              </StackPanel>

              <StackPanel Grid.Column="3">
                <TextBlock Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsNextCharge}" />
                <TextBlock Margin="0,4,0,0" FontWeight="SemiBold" Text="{Binding NextPaymentLabel}" />
                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SubscriptionsDeadlineStatus}" />
                <TextBlock Margin="0,4,0,0" Text="{Binding CountdownLabel}" />
              </StackPanel>

              <StackPanel Grid.Column="4" HorizontalAlignment="Right">
                <TextBlock Foreground="{DynamicResource AppMutedBrush}" HorizontalAlignment="Right" Text="{DynamicResource SubscriptionsState}" />
                <Border Margin="0,4,0,0"
                        Style="{StaticResource StatusBadgeBorderStyle}"
                        Background="{Binding StatusColorHex, Converter={StaticResource HexToBrushConverter}}">
                  <TextBlock Style="{StaticResource StatusBadgeTextStyle}" Text="{Binding StatusBadgeLabel}" />
                </Border>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </DockPanel>
</UserControl>
