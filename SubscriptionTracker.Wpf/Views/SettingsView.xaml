<UserControl x:Class="SubscriptionTracker.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>
      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="22" FontWeight="SemiBold" Text="{DynamicResource SettingsTitle}" />
          <TextBlock Margin="0,6,0,0"
                     Foreground="{DynamicResource AppMutedBrush}"
                     Text="{DynamicResource SettingsSubtitle}" />
        </StackPanel>
      </Border>

      <UniformGrid Columns="2" Margin="0,0,0,14">
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource SettingsGeneral}" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsBaseCurrency}" />
              <ComboBox Grid.Row="0" Grid.Column="1"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding CurrencyOptions}"
                        SelectedItem="{Binding SelectedCurrencyOption}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsLanguage}" />
              <ComboBox Grid.Row="1" Grid.Column="1"
                        Margin="0,14,0,0"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding LanguageOptions}"
                        SelectedItem="{Binding SelectedLanguageOption}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsTheme}" />
              <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Text="{Binding ThemeName}" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UseDarkThemeCommand}" Content="{DynamicResource SettingsDarkTheme}" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UseLightThemeCommand}" Content="{DynamicResource SettingsLightTheme}" />
              </StackPanel>

              <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsLaunchOnStartup}" />
              <CheckBox Grid.Row="3" Grid.Column="1"
                        Margin="0,14,0,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding LaunchOnStartup}" />

              <Button Grid.Row="4"
                      Grid.Column="1"
                      Margin="0,18,0,0"
                      HorizontalAlignment="Left"
                      Style="{StaticResource PrimaryButtonStyle}"
                      Command="{Binding SavePreferencesCommand}"
                      Content="{DynamicResource SettingsSavePreferences}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource SettingsReminders}" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsReminderCheck}" />
              <ComboBox Grid.Row="0" Grid.Column="1"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding ReminderIntervalOptions}"
                        SelectedItem="{Binding SelectedReminderIntervalOption}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsNotifications}" />
              <CheckBox Grid.Row="1" Grid.Column="1"
                        Margin="0,14,0,0"
                        IsChecked="{Binding AreNotificationsEnabled}" />
            </Grid>
          </StackPanel>
        </Border>
      </UniformGrid>

      <UniformGrid Columns="2">
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource SettingsStorage}" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsMode}" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StorageMode}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsDatabasePath}" />
              <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" TextWrapping="Wrap" Text="{Binding DatabasePath}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsBackups}" />
              <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,14,0,0">
                <TextBlock TextWrapping="Wrap" Text="{Binding BackupStatus}" />
                <WrapPanel Margin="0,12,0,0">
                  <Button Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding CreateBackupCommand}"
                          Content="{DynamicResource SettingsCreateBackup}" />
                  <Button Style="{StaticResource SecondaryButtonStyle}"
                          Command="{Binding RestoreBackupCommand}"
                          Content="{DynamicResource SettingsRestoreBackup}" />
                </WrapPanel>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource SettingsAbout}" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsVersion}" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="{DynamicResource SettingsDataProfile}" />
              <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Text="{Binding DataProfileText}" />
            </Grid>
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource SettingsCategories}" />
              <TextBlock Margin="0,6,0,0"
                         Foreground="{DynamicResource AppMutedBrush}"
                         Text="{DynamicResource SettingsCategoriesSubtitle}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top">
              <Button Style="{StaticResource PrimaryButtonStyle}"
                      Command="{Binding AddCategoryCommand}"
                      Content="{DynamicResource CategoryAdd}" />
              <Button Style="{StaticResource SecondaryButtonStyle}"
                      Command="{Binding EditCategoryCommand}"
                      Content="{DynamicResource CategoryEdit}" />
              <Button Style="{StaticResource DangerButtonStyle}"
                      Command="{Binding DeleteCategoryCommand}"
                      Content="{DynamicResource CategoryDelete}" />
            </WrapPanel>
          </Grid>

          <UniformGrid Columns="3" Margin="0,16,0,10">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
              <StackPanel>
                <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                           Text="{DynamicResource SettingsCategoriesTotal}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="28"
                           FontWeight="Bold"
                           Text="{Binding CategoryCount}" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
              <StackPanel>
                <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                           Text="{DynamicResource SettingsCategoriesCustom}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="28"
                           FontWeight="Bold"
                           Text="{Binding CustomCategoryCount}" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0">
              <StackPanel>
                <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                           Text="{DynamicResource SettingsCategoriesLinkedSubscriptions}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="28"
                           FontWeight="Bold"
                           Text="{Binding LinkedSubscriptionCount}" />
              </StackPanel>
            </Border>
          </UniformGrid>

          <ListBox ItemsSource="{Binding Categories}"
                   SelectedItem="{Binding SelectedCategory}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                      <Border Width="14"
                            Height="14"
                            Margin="0,4,12,0"
                            VerticalAlignment="Top"
                            CornerRadius="7"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}" />
                      <StackPanel>
                        <TextBlock FontSize="15"
                                 FontWeight="SemiBold"
                                 Text="{Binding Name}" />
                      <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                        <TextBlock Foreground="{DynamicResource AppMutedBrush}"
                                   Text="{Binding SubscriptionCount}" />
                        <TextBlock Margin="6,0,0,0"
                                   Foreground="{DynamicResource AppMutedBrush}"
                                   Text="{DynamicResource CategoryLinkedSubscriptions}" />
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Grid.Column="1"
                              HorizontalAlignment="Right">
                    <Border Background="{DynamicResource AppSecondaryCardBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1">
                      <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSystem}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                 Foreground="{DynamicResource AppForegroundBrush}"
                                 Text="{DynamicResource CategorySystem}" />
                    </Border>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
