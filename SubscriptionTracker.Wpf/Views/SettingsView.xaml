<UserControl x:Class="SubscriptionTracker.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>
      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="22" FontWeight="SemiBold" Text="{DynamicResource SettingsTitle}" />
          <TextBlock Margin="0,6,0,0"
                     Foreground="{DynamicResource AppMutedBrush}"
                     Text="Базовые параметры приложения, напоминаний и локального хранения." />
        </StackPanel>
      </Border>

      <UniformGrid Columns="2" Margin="0,0,0,14">
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Общие" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="Основная валюта" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BaseCurrency}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="Тема" />
              <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Text="{Binding ThemeName}" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UseDarkThemeCommand}" Content="Темная" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding UseLightThemeCommand}" Content="Светлая" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Напоминания" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="Проверка платежей" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ReminderCheckIntervalMinutes, StringFormat=Раз в {0} минут}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="Уведомления" />
              <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Text="{Binding NotificationsEnabled, StringFormat=Включены: {0}}" />
            </Grid>
          </StackPanel>
        </Border>
      </UniformGrid>

      <UniformGrid Columns="2">
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Хранилище" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="Режим" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StorageMode}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="Путь к БД" />
              <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" TextWrapping="Wrap" Text="{Binding DatabasePath}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="Резервные копии" />
              <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Text="{Binding BackupStatus}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="О приложении" />
            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource AppMutedBrush}" Text="Версия" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" />

              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Foreground="{DynamicResource AppMutedBrush}" Text="Профиль данных" />
              <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Text="Без облака, данные остаются на этом компьютере." />
            </Grid>
          </StackPanel>
        </Border>
      </UniformGrid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
